algoritmo "Exercício 3"

var

	largura:inteiro
  comprimento:inteiro
  area:real

inicio

	escreva("Qual a largura do terreno? ")
  	leia(largura)
    escreval(largura)
  escreva("Qual o comprimento do terreno? ")
  	leia(comprimento)
    escreval(comprimento)
  area<-(largura * comprimento)
  escreva("O cálculo da área com os respectivos valores é de: ",area)
fimalgoritmo